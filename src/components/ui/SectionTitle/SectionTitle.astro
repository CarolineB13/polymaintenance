---
import "./SectionTitle.css";

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  level?: "h1" | "h2" | "h3";
}

const { eyebrow, title, subtitle, level = "h2" } = Astro.props;

const Heading = level;
---

<div class="section-title">
  {eyebrow && <p class="section-title__eyebrow">{eyebrow}</p>}

  <Heading class="section-title__title">
    {title}
  </Heading>

  {subtitle && <p class="section-title__subtitle">{subtitle}</p>}
</div>
