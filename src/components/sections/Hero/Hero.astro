---
import Container from "../../ui/Container/Container.astro";
import SectionTitle from "../../ui/SectionTitle/SectionTitle.astro";
import Button from "../../ui/Button/Button.astro";

import herve from "../../../assets/images/herve.png";

import "./Hero.css";
---

<section class="hero">
  <Container>
    <div class="hero__content">
      <div class="hero__text">
        <SectionTitle
          eyebrow="Maintenance • Installation • Matériel industriel"
          title="À vos côtés pour la maintenance de vos équipements industriels"
          subtitle="Polymaintenance accompagne les professionnels dans la maintenance, l’installation et la fourniture de matériel industriel afin de garantir la performance et la continuité de leurs équipements."
          level="h1"
        />

        <div class="hero__actions">
          <Button href="/contact" label="Demander un devis" />

          <Button
            href="/realisations"
            label="Découvrir nos réalisations"
            variant="secondary"
          />
        </div>

        <ul class="hero__benefits">
          <li>Intervention rapide</li>
          <li>Solutions sur mesure</li>
          <li>Accompagnement de proximité</li>
        </ul>
      </div>

      <div class="hero__image">
        <img
          src={herve.src}
          alt="Hervé Giaufret en intervention de maintenance industrielle"
        />
      </div>
    </div>
  </Container>
</section>
